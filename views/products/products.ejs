<!DOCTYPE html>
<html lang="es">
  <!-- Include Head -->
  <%- include('../partials/head', {estilo: 'products'}) %>
  <body>
    <!-- Header -->
    <%- include('../partials/header') %>
    <!-- /nav-bar -->
    <%- include('../partials/nav-bar') %>
    <%-include ('../partials/button-top')%>
    <!-- todos los productos -->
    <div class="div-body">
      <div>
        <h2 class="products-title">Todos los productos</h2>
      </div>
      <% productos.forEach(product=>{%>
      
        <div class="container">
            <div class="product">
              
              <a href="/products/detail/<%= product.id %>" class="product-link">
            <img src="/images/products/<%= product.imagen  %>" alt="imagen de producto"/>
              
            <h2><%= product.nombre %></h2><br>
              <h4><%= product.marca.descripcion %></h4><br>
              <h4>$ <%= product.precio %></h4><br>
            </a>
              <!-- <i class="fas fa-truck"></i> -->
              <!-- <button class="boton-carrito" type="submit">Agregar al carrito</button> -->
              <form class="product-buttons" action="/shop-cart/add" method="POST">
                <input type="hidden" name="productoId" value="<%= product.id_productos %>">
                <button class="btn add-to-cart" type="submit">Agregar al carrito</button>
              </form>
              <!-- <a class="boton-enlace" href="/products/detail/<%= product.id_productos %>">Detalles</a> -->
            
        </div>
      </div>
          <%})%>
     
    </div>
    <%- include('../partials/footer') %>
  </body>
</html>
